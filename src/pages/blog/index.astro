---
/**
 * صفحة فهرس المدوّنة
 */

import BaseLayout from '@layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { SITE } from '../../consts';

const posts = await getCollection('blog', ({ data }) => !data.draft);
const sorted = posts.sort(
  (a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime()
);

const dateFormatter = new Intl.DateTimeFormat('ar-SA', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

// تجميع حسب الفئة
const categories = [...new Set(sorted.map((p) => p.data.category))];
---

<BaseLayout
  title="مدوّنة IPTV - أدلة ومراجعات ونصائح"
  description="مدوّنة ستريم ماستر برو: أدلة شاملة، مراجعات تفصيلية، ونصائح لاختيار أفضل اشتراك IPTV في السعودية والخليج."
>
  <section class="section">
    <div class="container-app">
      <header class="mx-auto mb-12 max-w-3xl text-center">
        <span class="badge mb-3">المدوّنة</span>
        <h1 class="mb-4 text-4xl font-black tracking-tight text-white sm:text-5xl lg:text-6xl">
          مقالات
          <span class="text-brand-red">IPTV</span>
          ودليل المشاهدة
        </h1>
        <p class="text-base text-gray-400 sm:text-lg">
          دليلك المتخصص لاختيار أفضل اشتراك IPTV، تثبيت التطبيقات، ومتابعة البطولات العالمية.
        </p>
      </header>

      {/* فلاتر الفئات */}
      <div class="mb-10 flex flex-wrap items-center justify-center gap-2">
        <button
          type="button"
          data-category="all"
          class="category-filter rounded-full border-2 border-brand-red bg-brand-red/10 px-5 py-2 text-sm font-black text-white transition-all"
        >
          كل المقالات ({sorted.length})
        </button>
        {
          categories.map((cat) => (
            <button
              type="button"
              data-category={cat}
              class="category-filter rounded-full border-2 border-white/10 bg-white/5 px-5 py-2 text-sm font-bold text-gray-400 transition-all hover:border-white/20 hover:text-white"
            >
              {cat}
            </button>
          ))
        }
      </div>

      {/* شبكة المقالات */}
      <div id="posts-grid" class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {
          sorted.map((post) => (
            <article
              class="card group overflow-hidden p-0"
              data-category={post.data.category}
            >
              <a href={`/blog/${post.slug}/`} class="block">
                {post.data.image && (
                  <div class="relative aspect-video-16-9 overflow-hidden bg-brand-bg-soft">
                    <img
                      src={post.data.image}
                      alt={post.data.imageAlt ?? post.data.title}
                      loading="lazy"
                      decoding="async"
                      class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-110"
                    />
                    <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent" />
                    {post.data.category && (
                      <span class="absolute right-3 top-3 rounded-full bg-brand-red/90 px-3 py-1 text-xs font-black text-white">
                        {post.data.category}
                      </span>
                    )}
                  </div>
                )}

                <div class="p-6">
                  <div class="mb-3 flex items-center gap-3 text-xs text-gray-500">
                    <time datetime={post.data.publishedAt.toISOString()}>
                      📅 {dateFormatter.format(post.data.publishedAt)}
                    </time>
                    {post.data.readingTime && (
                      <span>⏱️ {post.data.readingTime} دقيقة</span>
                    )}
                  </div>

                  <h2 class="mb-3 line-clamp-2 text-xl font-black leading-tight text-white transition-colors group-hover:text-brand-red-light">
                    {post.data.title}
                  </h2>

                  <p class="mb-4 line-clamp-3 text-sm leading-relaxed text-gray-400">
                    {post.data.excerpt}
                  </p>

                  <div class="flex items-center justify-between text-xs">
                    <span class="text-gray-500">{post.data.author}</span>
                    <span class="font-black text-brand-red-light">
                      اقرأ المزيد ←
                    </span>
                  </div>
                </div>
              </a>
            </article>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  // فلترة المقالات حسب الفئة
  const filters = document.querySelectorAll<HTMLButtonElement>('.category-filter');
  const posts = document.querySelectorAll<HTMLElement>('#posts-grid > article');

  filters.forEach((filter) => {
    filter.addEventListener('click', () => {
      const target = filter.dataset.category;

      filters.forEach((f) => {
        f.classList.remove('border-brand-red', 'bg-brand-red/10', 'text-white');
        f.classList.add('border-white/10', 'bg-white/5', 'text-gray-400');
      });
      filter.classList.add('border-brand-red', 'bg-brand-red/10', 'text-white');
      filter.classList.remove('border-white/10', 'bg-white/5', 'text-gray-400');

      posts.forEach((post) => {
        if (target === 'all' || post.dataset.category === target) {
          post.style.display = '';
        } else {
          post.style.display = 'none';
        }
      });
    });
  });
</script>
