---
/**
 * صفحة سيرفر فردي - ديناميكية لكل سيرفر من الخمسة
 */

import BaseLayout from '@layouts/BaseLayout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { SERVERS, SERVER_ORDER } from '../../lib/servers';
import { SERVER_PRICING, formatPrice, type ServerName } from '../../lib/pricing';
import { productSchema, breadcrumbSchema, fullUrl } from '../../lib/seo';
import { SITE } from '../../consts';

export async function getStaticPaths() {
  const servers = await getCollection('servers', ({ data }) => !data.draft);
  return servers.map((server) => ({
    params: { name: server.data.name },
    props: { server },
  }));
}

interface Props {
  server: CollectionEntry<'servers'>;
}

const { server } = Astro.props as Props;
const { Content } = await server.render();

const serverName = server.data.name as ServerName;
const serverInfo = SERVERS[serverName];
const pricing = SERVER_PRICING[serverName];

const canonicalUrl = fullUrl(`/servers/${serverName}/`);

const schemas = [
  productSchema({
    name: `اشتراك IPTV سيرفر ${serverInfo.displayName}`,
    description: server.data.tagline,
    price: pricing.plans[0]?.priceSar ?? 0,
    url: canonicalUrl,
    rating: { value: 4.8, count: 250 },
  }),
  breadcrumbSchema([
    { name: 'الرئيسية', url: SITE.url },
    { name: 'السيرفرات', url: fullUrl('/servers/') },
    { name: serverInfo.displayName, url: canonicalUrl },
  ]),
];

const colorClass = {
  red: 'from-red-500/20 to-red-900/20 border-red-500/40',
  amber: 'from-amber-500/20 to-amber-900/20 border-amber-500/40',
  green: 'from-green-500/20 to-green-900/20 border-green-500/40',
  blue: 'from-blue-500/20 to-blue-900/20 border-blue-500/40',
  purple: 'from-purple-500/20 to-purple-900/20 border-purple-500/40',
}[server.data.color];
---

<BaseLayout
  title={`${serverInfo.displayName} IPTV - ${server.data.tagline}`}
  description={server.data.description}
  additionalSchema={schemas}
>
  {/* Hero مخصص للسيرفر */}
  <section class:list={['relative overflow-hidden pt-12 sm:pt-16']}>
    <div
      aria-hidden="true"
      class:list={['absolute inset-0 -z-10 bg-gradient-to-br', colorClass]}
    >
    </div>

    <div class="container-app">
      <nav class="mb-6 text-sm text-gray-400" aria-label="مسار التنقل">
        <ol class="flex flex-wrap items-center gap-2">
          <li><a href="/" class="hover:text-white">الرئيسية</a></li>
          <li aria-hidden="true">/</li>
          <li><a href="/servers/" class="hover:text-white">السيرفرات</a></li>
          <li aria-hidden="true">/</li>
          <li class="text-white">{serverInfo.displayName}</li>
        </ol>
      </nav>

      <div class="grid items-center gap-8 lg:grid-cols-2">
        <div>
          {serverInfo.badge && (
            <span class="badge mb-4 bg-brand-red text-white">{serverInfo.badge}</span>
          )}

          <h1 class="mb-4 text-4xl font-black leading-tight text-white sm:text-5xl lg:text-6xl">
            سيرفر
            <span class="text-brand-red">{serverInfo.displayName}</span>
            {serverInfo.icon}
          </h1>

          <p class="mb-4 text-xl font-bold text-amber-300">
            {server.data.tagline}
          </p>

          <p class="mb-8 max-w-xl text-base leading-relaxed text-gray-300 sm:text-lg">
            {server.data.description}
          </p>

          <div class="flex flex-wrap items-center gap-4">
            <a href="/store/" class="btn-primary">
              <span>اشترك الآن</span>
            </a>
            <a
              href={`https://wa.me/${SITE.whatsapp.replace('+', '')}?text=${encodeURIComponent(
                `مرحبًا، أرغب في معرفة تفاصيل سيرفر ${serverInfo.displayName}`
              )}`}
              target="_blank"
              rel="noopener"
              class="btn-secondary"
            >
              <span>💬 استفسر</span>
            </a>
          </div>
        </div>

        {/* بطاقة المواصفات */}
        <div class="card">
          <h2 class="mb-6 text-2xl font-black text-white">المواصفات</h2>
          <div class="grid grid-cols-2 gap-3">
            <div class="rounded-xl border border-white/10 bg-white/5 p-4">
              <p class="text-xs text-gray-400">أقصى جودة</p>
              <p class="text-2xl font-black text-white">{server.data.specs.quality}</p>
            </div>
            <div class="rounded-xl border border-white/10 bg-white/5 p-4">
              <p class="text-xs text-gray-400">الثبات</p>
              <p class="num-latin text-2xl font-black text-green-400">{server.data.specs.uptime}</p>
            </div>
            <div class="rounded-xl border border-white/10 bg-white/5 p-4">
              <p class="text-xs text-gray-400">الأجهزة المتزامنة</p>
              <p class="num-latin text-2xl font-black text-white">
                حتى {server.data.specs.devices}
              </p>
            </div>
            <div class="rounded-xl border border-white/10 bg-white/5 p-4">
              <p class="text-xs text-gray-400">عدد القنوات</p>
              <p class="num-latin text-2xl font-black text-white">{server.data.specs.channels}</p>
            </div>
            <div class="rounded-xl border border-white/10 bg-white/5 p-4">
              <p class="text-xs text-gray-400">مكتبة VOD</p>
              <p class="num-latin text-2xl font-black text-white">{server.data.specs.vod}</p>
            </div>
            <div class="rounded-xl border border-white/10 bg-white/5 p-4">
              <p class="text-xs text-gray-400">Catch-up</p>
              <p class="text-2xl font-black text-white">{server.data.specs.catchup}</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* جدول الأسعار */}
  <section class="section">
    <div class="container-app">
      <div class="mb-10 text-center">
        <h2 class="section-title">خطط الأسعار</h2>
        <p class="section-subtitle">اختر المدة المناسبة لك.</p>
      </div>

      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-4">
        {
          pricing.plans.map((plan) => (
            <article
              class:list={[
                'price-card',
                plan.popular && 'lg:scale-105 lg:shadow-2xl lg:shadow-red-500/20',
              ]}
              data-popular={plan.popular ? 'true' : undefined}
            >
              {plan.popular && (
                <div class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-brand-red px-4 py-1 text-xs font-black text-white shadow-lg">
                  ⭐ الأكثر طلباً
                </div>
              )}

              <h3 class="mb-4 text-xl font-black text-white">{plan.label}</h3>

              <div class="mb-2 flex items-baseline gap-2">
                <span class="num-latin text-4xl font-black text-white">
                  {formatPrice(plan.priceSar)}
                </span>
              </div>

              {plan.originalPrice && (
                <div class="mb-2 flex items-center gap-2 text-xs">
                  <span class="num-latin text-gray-500 line-through">
                    {formatPrice(plan.originalPrice)}
                  </span>
                  {plan.savePercent && (
                    <span class="badge bg-green-500/10 text-green-400">
                      وفّر {plan.savePercent}%
                    </span>
                  )}
                </div>
              )}

              <div class="my-6 h-px bg-white/10" />

              <ul class="mb-6 space-y-2 text-sm">
                {plan.features.map((feature) => (
                  <li class="flex items-center gap-2 text-gray-300">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="3"
                      class="h-4 w-4 shrink-0 text-green-400"
                    >
                      <path d="M5 13l4 4L19 7" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                    <span>{feature}</span>
                  </li>
                ))}
              </ul>

              <a
                href={`https://wa.me/${SITE.whatsapp.replace('+', '')}?text=${encodeURIComponent(
                  `مرحبًا، أرغب في الاشتراك في سيرفر ${serverInfo.displayName} - باقة ${plan.label}`
                )}`}
                target="_blank"
                rel="noopener"
                class:list={[
                  'flex w-full items-center justify-center gap-2 rounded-xl px-4 py-3 text-sm font-black transition-all',
                  plan.popular
                    ? 'bg-brand-red text-white shadow-lg shadow-red-500/30 hover:bg-red-700'
                    : 'border border-white/20 bg-white/5 text-white hover:bg-white/10',
                ]}
              >
                <span>اطلب الآن</span>
              </a>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  {/* محتوى السيرفر من Markdown */}
  <section class="section">
    <div class="container-app max-w-3xl">
      <div class="prose prose-invert max-w-none prose-headings:font-black prose-headings:text-white">
        <Content />
      </div>
    </div>
  </section>

  {/* سيرفرات أخرى */}
  <section class="section">
    <div class="container-app">
      <h2 class="section-title mb-8 text-center">سيرفرات أخرى</h2>
      <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-4">
        {
          SERVER_ORDER.filter((k) => k !== serverName).map((key) => {
            const s = SERVERS[key];
            return (
              <a
                href={`/servers/${key}/`}
                class="card flex items-center gap-3 transition-all hover:scale-105"
              >
                <div class="text-3xl">{s.icon}</div>
                <div>
                  <h3 class="font-black text-white">{s.displayName}</h3>
                  <p class="text-xs text-gray-400">{s.tagline}</p>
                </div>
              </a>
            );
          })
        }
      </div>
    </div>
  </section>
</BaseLayout>
