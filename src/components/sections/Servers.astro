---
/**
 * Servers Section - عرض السيرفرات الخمسة
 * يستخدم SERVERS data من src/lib/servers.ts
 */

import { SERVERS, SERVER_ORDER } from '../../lib/servers';
import { SERVER_PRICING } from '../../lib/pricing';
import { formatPrice } from '../../lib/pricing';
---

<section class="section relative" aria-labelledby="servers-heading">
  <div class="container-app">
    <div class="mb-12 text-center">
      <span class="badge mb-3">اختر سيرفرك</span>
      <h2 id="servers-heading" class="section-title">
        اختر
        <span class="text-brand-red">سيرفرك</span>
        المثالي
      </h2>
      <p class="section-subtitle">
        خمسة سيرفرات مختلفة، كل واحد يتميز بمواصفات فريدة. اختر ما يناسب جهازك وميزانيتك.
      </p>
    </div>

    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {
        SERVER_ORDER.map((key) => {
          const server = SERVERS[key];
          const cheapestPrice = SERVER_PRICING[key].plans[0]?.priceSar ?? 0;
          const colorClass = {
            red: 'from-red-500/20 to-red-900/20 border-red-500/30',
            amber: 'from-amber-500/20 to-amber-900/20 border-amber-500/30',
            green: 'from-green-500/20 to-green-900/20 border-green-500/30',
            blue: 'from-blue-500/20 to-blue-900/20 border-blue-500/30',
            purple: 'from-purple-500/20 to-purple-900/20 border-purple-500/30',
          }[server.color];

          return (
            <article
              class:list={[
                'card group relative overflow-hidden border-2 transition-all hover:scale-[1.02] hover:shadow-2xl',
                colorClass,
              ]}
            >
              {/* شارة */}
              {server.badge && (
                <span class="absolute right-4 top-4 badge bg-brand-red text-white">
                  {server.badge}
                </span>
              )}

              {/* الأيقونة والعنوان */}
              <div class="mb-6 flex items-start gap-4">
                <div
                  class:list={[
                    'flex h-16 w-16 shrink-0 items-center justify-center rounded-2xl bg-gradient-to-br shadow-lg',
                    server.color === 'red' && 'from-red-500 to-red-700 shadow-red-500/30',
                    server.color === 'amber' && 'from-amber-400 to-amber-600 shadow-amber-500/30',
                    server.color === 'green' && 'from-green-500 to-green-700 shadow-green-500/30',
                    server.color === 'blue' && 'from-blue-500 to-blue-700 shadow-blue-500/30',
                    server.color === 'purple' && 'from-purple-500 to-purple-700 shadow-purple-500/30',
                  ]}
                >
                  <span class="text-3xl">{server.icon}</span>
                </div>
                <div class="flex-1">
                  <h3 class="text-2xl font-black text-white">{server.displayName}</h3>
                  <p class="text-sm text-gray-400">{server.tagline}</p>
                </div>
              </div>

              <p class="mb-6 text-sm leading-relaxed text-gray-300">
                {server.description}
              </p>

              {/* المواصفات */}
              <div class="mb-6 grid grid-cols-2 gap-3 text-xs">
                <div class="rounded-lg border border-white/5 bg-white/5 p-3">
                  <p class="text-gray-500">الجودة</p>
                  <p class="font-black text-white">{server.specs.quality}</p>
                </div>
                <div class="rounded-lg border border-white/5 bg-white/5 p-3">
                  <p class="text-gray-500">الثبات</p>
                  <p class="num-latin font-black text-green-400">{server.specs.uptime}</p>
                </div>
                <div class="rounded-lg border border-white/5 bg-white/5 p-3">
                  <p class="text-gray-500">الأجهزة</p>
                  <p class="num-latin font-black text-white">حتى {server.specs.devices}</p>
                </div>
                <div class="rounded-lg border border-white/5 bg-white/5 p-3">
                  <p class="text-gray-500">القنوات</p>
                  <p class="num-latin font-black text-white">{server.specs.channels}</p>
                </div>
              </div>

              {/* السعر */}
              <div class="mb-6 flex items-baseline gap-2 border-t border-white/10 pt-4">
                <span class="num-latin text-3xl font-black text-white">
                  {formatPrice(cheapestPrice)}
                </span>
                <span class="text-sm text-gray-400">/ شهر</span>
              </div>

              {/* زر */}
              <a
                href={`/servers/${key}/`}
                class="flex w-full items-center justify-center gap-2 rounded-xl border border-white/20 bg-white/5 px-4 py-3 text-sm font-black text-white transition-all hover:bg-white/10"
              >
                <span>اعرف المزيد</span>
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="3"
                  class="h-4 w-4 rotate-180"
                >
                  <path d="M15 19l-7-7 7-7" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </a>
            </article>
          );
        })
      }
    </div>
  </div>
</section>
