---
/**
 * CTA Section - دعوة لإجراء في نهاية الصفحة الرئيسية
 */

import { SITE } from '../../consts';
---

<section
  class="section relative overflow-hidden"
  aria-labelledby="cta-heading"
>
  {/* خلفية ديكورية */}
  <div
    aria-hidden="true"
    class="absolute inset-0 -z-10 bg-gradient-to-br from-brand-red/20 via-brand-bg to-purple-900/20"
  >
  </div>
  <div
    aria-hidden="true"
    class="absolute right-1/4 top-0 -z-10 h-96 w-96 rounded-full bg-brand-red/30 blur-[120px]"
  >
  </div>
  <div
    aria-hidden="true"
    class="absolute bottom-0 left-1/4 -z-10 h-96 w-96 rounded-full bg-purple-600/30 blur-[120px]"
  >
  </div>

  <div class="container-app relative">
    <div class="mx-auto max-w-3xl rounded-3xl border border-white/10 bg-brand-bg/60 p-8 text-center backdrop-blur-2xl sm:p-12">
      <span class="mb-4 inline-block text-5xl sm:text-6xl">🎉</span>
      <h2 id="cta-heading" class="mb-4 text-3xl font-black text-white sm:text-4xl">
        جاهز لتجربة مشاهدة لا مثيل لها؟
      </h2>
      <p class="mb-8 text-base leading-relaxed text-gray-300 sm:text-lg">
        انضم إلى
        <strong class="text-white">+50,000 مشترك</strong>
        في السعودية والخليج يثقون في ستريم ماستر برو.
        ابدأ اليوم مع ضمان استرداد كامل خلال 7 أيام.
      </p>

      <div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a href="/store/" class="btn-primary text-base sm:text-lg">
          <span>ابدأ الاشتراك</span>
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="currentColor"
            class="h-5 w-5"
          >
            <path d="M8 5v14l11-7z" />
          </svg>
        </a>
        <a
          href={`https://wa.me/${SITE.whatsapp.replace('+', '')}`}
          target="_blank"
          rel="noopener"
          class="btn-secondary"
        >
          <span>💬 استفسر أولاً</span>
        </a>
      </div>

      {/* ضمانات */}
      <div class="mt-8 flex flex-wrap items-center justify-center gap-6 text-xs text-gray-400">
        <div class="flex items-center gap-2">
          <span>✅</span>
          <span>ضمان 7 أيام</span>
        </div>
        <div class="flex items-center gap-2">
          <span>✅</span>
          <span>دعم 24/7</span>
        </div>
        <div class="flex items-center gap-2">
          <span>✅</span>
          <span>تفعيل فوري</span>
        </div>
        <div class="flex items-center gap-2">
          <span>✅</span>
          <span>دفع آمن</span>
        </div>
      </div>
    </div>
  </div>
</section>
