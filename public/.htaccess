# =============================================================================
# Stream Master Pro — Apache config for Hostinger
# ضع هذا الملف في public_html بعد رفع dist/
# =============================================================================

# Use UTF-8 by default
AddDefaultCharset UTF-8

# Force HTTPS
<IfModule mod_rewrite.c>
  RewriteEngine On

  RewriteCond %{HTTPS} !=on
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # Custom 404
  ErrorDocument 404 /404.html
</IfModule>

# Compression
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript
  AddOutputFilterByType DEFLATE application/javascript application/json application/xml
  AddOutputFilterByType DEFLATE image/svg+xml font/woff font/woff2
</IfModule>

# Caching
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/avif           "access plus 30 days"
  ExpiresByType image/webp           "access plus 30 days"
  ExpiresByType image/jpeg           "access plus 30 days"
  ExpiresByType image/png            "access plus 30 days"
  ExpiresByType image/svg+xml        "access plus 30 days"
  ExpiresByType font/woff2           "access plus 365 days"
  ExpiresByType text/css             "access plus 7 days"
  ExpiresByType application/javascript "access plus 7 days"
  ExpiresByType text/html            "access plus 0 seconds"
</IfModule>

# Security headers
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Permissions-Policy "geolocation=(), microphone=(), camera=()"

  <FilesMatch "\.(?:avif|webp|jpe?g|png|svg|ico|woff2?)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>

  <If "%{REQUEST_URI} =~ m#^/_assets/#">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </If>

  <FilesMatch "^(?:sw|OneSignalSDKWorker)\.js$">
    Header set Cache-Control "public, max-age=0, must-revalidate"
  </FilesMatch>

  <FilesMatch "\.html$">
    Header set Cache-Control "public, max-age=0, must-revalidate"
  </FilesMatch>
</IfModule>

# MIME types
<IfModule mod_mime.c>
  AddType image/webp .webp
  AddType image/avif .avif
  AddType application/manifest+json .webmanifest
</IfModule>
